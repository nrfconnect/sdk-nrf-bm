menuconfig BM_RMEM_CLIPBOARD
	bool "Inter application RAM Clipboard"
	help
	  If enabled, instance of simple inter application
	  clipboard storage on retained RAM area is supported.
	  The storage is using RAM memory partition described in the DTS node of
	  zephyr,retained-ram compatible.

if BM_RMEM_CLIPBOARD

module = BM_RMEM_CLIPBOARD
module-str = bm_rmem_clipboard
source "subsys/logging/Kconfig.template.log_config"

endif
